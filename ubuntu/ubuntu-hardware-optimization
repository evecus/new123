# Modified for Ubuntu / panther-x2 (RK3566) — removed unrelated board IRQ cases

. /etc/ubuntu-release
. /usr/lib/ubuntu/ubuntu-common

set_io_scheduler() {
	KERNELID=$(uname -r | awk -F'.' '{print ($1 * 100) + $2}')
	for i in $(lsblk -idn -o NAME | grep -v zram); do
		read ROTATE < /sys/block/$i/queue/rotational
		case ${ROTATE} in
			1) [[ $KERNELID -lt 420 ]] && sched=cfq || sched=bfq ;;
			0) [[ $KERNELID -lt 420 ]] && sched=noop || sched=none ;;
			*) continue ;;
		esac
		echo $sched > /sys/block/$i/queue/scheduler
		echo "### [hw-opt] I/O scheduler: $sched for $i" >> "${Log}"
	done
}

prepare_board() {
	# logrotate 路径修正（zram ramlog 场景）
	CheckDevice=$(for i in /var/log /var /; do findmnt -n -o SOURCE $i && break; done)
	if [[ "${CheckDevice}" == *"/dev/zram"* || "${CheckDevice}" == "armbian-ramlog" ]]; then
		for f in /etc/logrotate.d/*; do sed -i "s|/var/log/|/var/log.hdd/|g" "${f}"; done
		sed -i "s|/var/log/|/var/log.hdd/|g" /etc/logrotate.conf
	else
		for f in /etc/logrotate.d/*; do sed -i "s|/var/log.hdd/|/var/log/|g" "${f}"; done
		sed -i "s|/var/log.hdd/|/var/log/|g" /etc/logrotate.conf
	fi

	# cpufreq 权限修正
	for f in /sys/devices/system/cpu/cpufreq/*/cpuinfo_cur_freq; do
		[[ -f "$f" ]] && chmod +r "$f" 2>/dev/null || true
	done
	[[ -f /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_cur_freq ]] && \
		chmod +r /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_cur_freq 2>/dev/null || true

	# logrotate compress
	find /etc/logrotate.d/. -type f | xargs grep -H -c 'compress' | grep '0$' | \
		cut -d':' -f1 | xargs -r -L1 sed -i '/{/ a compress'
	sed -i "s/#compress/compress/" /etc/logrotate.conf

	# CPU governor（从 /etc/default/cpufrequtils 读取）
	if [[ -r /etc/default/cpufrequtils ]]; then
		. /etc/default/cpufrequtils
		for cluster in /sys/devices/system/cpu/cpufreq/policy*; do
			[[ -e "${cluster}" ]] || break
			grep -q "${GOVERNOR}" "${cluster}/scaling_available_governors" 2>/dev/null && \
				[[ -w "${cluster}/scaling_governor" ]] && echo "${GOVERNOR}" > "${cluster}/scaling_governor"
			[[ -n "${MIN_SPEED}" && -w "${cluster}/scaling_min_freq" ]] && echo "${MIN_SPEED}" > "${cluster}/scaling_min_freq"
			[[ -n "${MAX_SPEED}" && -w "${cluster}/scaling_max_freq" ]] && echo "${MAX_SPEED}" > "${cluster}/scaling_max_freq"
		done
	fi

	# IRQ 亲和性：按 SOC 家族区分
	case "${BOARDFAMILY}" in
		rk3566|rk3568)
			# 4/6核，xhci→cpu2(mask=4), Mali→cpu1(mask=2)
			for i in $(awk -F':' '/xhci/{print $1}' /proc/interrupts | sed 's/ //g'); do
				echo 4 > /proc/irq/$i/smp_affinity 2>/dev/null || true
			done
			for i in $(awk -F':' '/Mali|mali|gpu/{print $1}' /proc/interrupts | sed 's/ //g'); do
				echo 2 > /proc/irq/$i/smp_affinity 2>/dev/null || true
			done
			;;
		rk3588|rk3588s)
			# 8核 big.LITTLE，大核 cpu4-7(mask=f0)
			for i in $(awk -F':' '/xhci/{print $1}' /proc/interrupts | sed 's/ //g'); do
				echo f0 > /proc/irq/$i/smp_affinity 2>/dev/null || true
			done
			for i in $(awk -F':' '/Mali|mali|gpu/{print $1}' /proc/interrupts | sed 's/ //g'); do
				echo f0 > /proc/irq/$i/smp_affinity 2>/dev/null || true
			done
			;;
		rk3576)
			# 8核 big.LITTLE，大核 cpu4-7(mask=f0)
			for i in $(awk -F':' '/xhci/{print $1}' /proc/interrupts | sed 's/ //g'); do
				echo f0 > /proc/irq/$i/smp_affinity 2>/dev/null || true
			done
			;;
		rk3399)
			# 6核 big.LITTLE，大核 cpu4-5(mask=30)
			for i in $(awk -F':' '/xhci/{print $1}' /proc/interrupts | sed 's/ //g'); do
				echo 30 > /proc/irq/$i/smp_affinity 2>/dev/null || true
			done
			;;
		rk3328|rk3318|rk3528)
			# 4核同构，绑 cpu2-3(mask=c)
			for i in $(awk -F':' '/xhci/{print $1}' /proc/interrupts | sed 's/ //g'); do
				echo c > /proc/irq/$i/smp_affinity 2>/dev/null || true
			done
			;;
	esac
	# 等待网卡 IRQ 出现（最多5秒）
	for i in {1..5}; do
		grep -qE 'eth0|end0' /proc/interrupts && break
		sleep 1
	done
	ETH_IFACE=$(ip -o link | awk -F': ' '/eth|end/{print $2; exit}' | sed 's/@.*//')
	if [[ -n "${ETH_IFACE}" ]]; then
		for i in $(awk -F':' "/${ETH_IFACE}/{print \$1}" /proc/interrupts | sed 's/ //g'); do
			echo 8 > /proc/irq/$i/smp_affinity 2>/dev/null || true
		done
		echo 7 > /sys/class/net/${ETH_IFACE}/queues/rx-0/rps_cpus 2>/dev/null || true
		echo 32768 > /proc/sys/net/core/rps_sock_flow_entries 2>/dev/null || true
		echo 32768 > /sys/class/net/${ETH_IFACE}/queues/rx-0/rps_flow_cnt 2>/dev/null || true
	fi

	echo "### [hw-opt] board preparation done (${BOARD}/${BOARDFAMILY})" >> "${Log}"
}

update_branch_from_installed_kernel() {
	BRANCH=$(dpkg -l | grep -E "linux-image" | grep -E "current|legacy|edge" | \
		awk '{print $2}' | cut -d'-' -f3 | head -1)
	if grep -q BRANCH /etc/ubuntu-release 2>/dev/null; then
		[[ -n "${BRANCH}" ]] && sed -i "s/BRANCH=.*/BRANCH=${BRANCH}/" /etc/ubuntu-release
	else
		[[ -n "${BRANCH}" ]] && echo "BRANCH=${BRANCH}" >> /etc/ubuntu-release
	fi
}

case $1 in
	*start*)
		touch "${Log}"; chmod 644 "${Log}"
		set_io_scheduler &
		prepare_board &
		update_branch_from_installed_kernel &
		wait
		;;
esac
